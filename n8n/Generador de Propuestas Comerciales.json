        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n    let rawText = '';\n    if (item.json.content && Array.isArray(item.json.content) && item.json.content[0] && item.json.content[0].text) {\n          rawText = item.json.content[0].text;\n    } else if (item.json.text) {\n          rawText = item.json.text;\n    }\n    rawText = (rawText || '').trim();\n\n    let parsed;\n    try {\n          parsed = JSON.parse(rawText);\n    } catch (e1) {\n      try {\n              const start = rawText.indexOf('{');\n              const end = rawText.lastIndexOf('}');\n              const jsonSlice = rawText.substring(start, end + 1);\n              parsed = JSON.parse(jsonSlice);\n      } catch (e2) {\n        parsed = {\n                  propuesta: 'ERROR: no se pudo parsear la respuesta de la IA. Revisar manualmente.',\n                  precio_estimado: 0,\n                  duracion_estimada: 'N/A',\n                  nivel_confianza: 'Bajo'\n        };\n      }\n    }\n\n    results.push({\n          json: {\n                  pageId: $('Notion Trigger').item.json.id,\n                  propuesta: parsed.propuesta || '',\n                  precio_estimado: Number(parsed.precio_estimado) || 0,\n                  duracion_estimada: parsed.duracion_estimada || '',\n                  nivel_confianza: parsed.nivel_confianza || 'Bajo'\n          }\n    });\n}\n\nreturn results;"
      },
